# Copy this to .env and fill in real values (never commit .env)

# REQUIRED in production — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Path to SQLite DB file — set to /data/bakugan.db on Railway (persistent volume)
DB_PATH=./bakugan.db

# Port (Railway sets this automatically)
PORT=3000

# Set to "production" on Railway
NODE_ENV=development
